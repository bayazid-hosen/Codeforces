#include <iostream>
#include <cmath>

using namespace std;

void solve() {
    int n, k, p;
    cin >> n >> k >> p;

    int steps_needed = (abs(k) + p - 1) / p; // Compute required steps with ceiling division

    if (steps_needed > n) {
        cout << -1 << endl;
    } else {
        cout << steps_needed << endl;
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    return 0;
}
